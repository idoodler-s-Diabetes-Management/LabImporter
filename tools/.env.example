# Copy this file to tools/.env (gitignored) and fill in the values.
# `tools/sync_loinc.py` reads these at runtime to authenticate against
# https://fhir.loinc.org/. Never commit the populated file.

LOINC_USERNAME=
LOINC_PASSWORD=

# Optional overrides. Defaults match tools/sync_loinc.py.
# LOINC_VALUESET=http://loinc.org/vs/top-2000-plus-lab-results-us
# LOINC_LANGUAGES=de,fr,es,it,nl,pt,pl,ja,zh
